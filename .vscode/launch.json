{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Go (Development)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/api",
      "cwd": "${workspaceFolder}",
      "env": {
        "APP_ENV": "Development",
        "PORT": "8080"
      },
      "console": "integratedTerminal"
    },
    {
      "name": "Run Go (Production)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/api",
      "env": {
        "APP_ENV": "Production",
        "PORT": "9000"
      },
      "console": "integratedTerminal"
    }
  ]
}